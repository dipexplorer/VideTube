# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB
# Example:
# DB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net
DB_URL=mongodb://127.0.0.1:27017

# JWT
JWT_ACCESS_TOKEN_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_TOKEN_EXPIRY=1d
JWT_REFRESH_TOKEN_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_TOKEN_EXPIRY=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
